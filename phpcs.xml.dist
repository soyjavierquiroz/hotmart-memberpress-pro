<?xml version="1.0"?>
<ruleset name="Hotmart MemberPress Pro">
	<description>Basic WordPress coding standards for Hotmart MemberPress Pro.</description>
	<file>hotmart-memberpress-pro.php</file>
	<file>includes</file>
	<file>uninstall.php</file>
	<arg name="extensions" value="php"/>
	<rule ref="WordPress"/>
	<exclude-pattern>vendor/*</exclude-pattern>
</ruleset>
